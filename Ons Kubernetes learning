        readinessProbe:
          httpGet:
            path: /           # The "door" Kubernetes knocks on
            port: 8080        # The port your app listens on
          initialDelaySeconds: 20  # Wait 20s before the first knock
          periodSeconds: 5         # Knock every 5s after that
        
        livenessProbe:
          httpGet:
            path: /
            port: 8080
          initialDelaySeconds: 40  # Wait 40s (longer than readiness)
          periodSeconds: 10        # Check every 10s

```

